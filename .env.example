# VOS-RS Docker Compose 环境变量配置
# 复制此文件为 .env 并修改配置

# ========== 数据库 ==========
POSTGRES_USER=vos_rs
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=vos_rs
POSTGRES_PORT=5432

# ========== NATS ==========
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_USER=nats_admin
NATS_PASSWORD=change-me-in-production

# ========== SIP 配置 ==========
SIP_ADVERTISED_ADDR=sip-edge:5060
SIP_DEFAULT_GATEWAY=127.0.0.1:5070
SIP_UDP_PORT=5060
SIP_TCP_PORT=5060
SIP_UDP_RECEIVE_BUFFER=4194304
SIP_UDP_SEND_BUFFER=4194304
SIP_AUTH_USERS=1001:secret,1002:secret
SIP_AUTH_REALM=vos-rs

# ========== RTP 配置 ==========
RTP_ADVERTISED_ADDR=sip-edge
RTP_PORT_MIN=40000
RTP_PORT_MAX=40100
RTP_SYMMETRIC_LEARNING=true
RTP_ANTI_SPOOFING=true

# ========== 录音配置 ==========
RECORDING_ENABLED=true
RECORDING_WORKERS=4
RECORDING_QUEUE_CAPACITY=4096
RECORDING_RETENTION_SECS=604800

# ========== 录音对象存储（RustFS / S3 兼容） ==========
STORAGE_BACKEND=oss
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_BUCKET=recordings
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_KEY_PREFIX=recordings/
RUSTFS_REGION=us-east-1

# ========== API 配置 ==========
API_PORT=8080
MANAGE_PORT=8082
WEB_PORT=3000

# ========== 安全密钥（生产环境必须修改） ==========
JWT_SECRET=change-me-in-production
INTERNAL_SECRET=change-me-in-production
ADMIN_PASSWORD=admin123
OPERATOR_PASSWORD=operator123
FINANCIER_PASSWORD=financier123

# ========== CORS ==========
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ========== CDR Worker ==========
CDR_BATCH_SIZE=50
CDR_BATCH_TIMEOUT_MS=100
CDR_MAX_DELIVERIES=5

# ========== 日志 ==========
RUST_LOG=sip_edge=info,api_server=info,cdr_worker=info
