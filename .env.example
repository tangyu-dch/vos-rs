# ==========================================
# vos-rs 环境变量模板文件 (.env.example)
# 复制此文件至 .env 或 .env.production 并配置真实敏感信息
# ==========================================

# 应用运行环境 (development / staging / production)
APP_ENV=development

# 数据库连接配置 (PostgreSQL)
VOS_RS_DATABASE_URL=postgres://vos:vos_secret_pass@localhost:5432/vos_db
VOS_RS_DATABASE_MAX_CONNECTIONS=50

# Redis 缓存与锁配置
VOS_RS_REDIS_URL=redis://:redis_secret_pass@localhost:6379/0

# NATS JetStream 消息队列
VOS_RS_NATS_URL=nats://localhost:4222

# REST API 访问凭证 (生产环境切勿使用默认凭证)
VOS_RS_ADMIN_PASSWORD=CHANGE_ME_ADMIN_SECURE_PASSWORD
VOS_RS_OPERATOR_PASSWORD=CHANGE_ME_OPERATOR_SECURE_PASSWORD
VOS_RS_FINANCIER_PASSWORD=CHANGE_ME_FINANCIER_SECURE_PASSWORD
VOS_RS_JWT_SECRET=CHANGE_ME_RANDOM_LONG_JWT_SECRET_KEY_32BYTES_PLUS

# 阿里云 / S3 录音存储凭证
VOS_RS_STORAGE_PROVIDER=local # local / oss / dual
VOS_RS_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
VOS_RS_OSS_BUCKET=vos-recordings
VOS_RS_OSS_ACCESS_KEY_ID=YOUR_OSS_ACCESS_KEY_ID
VOS_RS_OSS_ACCESS_KEY_SECRET=YOUR_OSS_ACCESS_KEY_SECRET

# SIP 信令与媒体端口
VOS_RS_SIP_BIND_IP=0.0.0.0
VOS_RS_SIP_BIND_PORT=5060
VOS_RS_RTP_PORT_MIN=10000
VOS_RS_RTP_PORT_MAX=20000

# IVR TTS/ASR 引擎 (sherpa-onnx, 通过 scripts/download_ivr_models.sh 下载模型)
VOS_RS_IVR_TTS_ENABLED=false
VOS_RS_IVR_TTS_MODEL_PATH=models/ivr/vits-icefall-zh-aishell3/model.onnx
VOS_RS_IVR_TTS_TOKENS_PATH=models/ivr/vits-icefall-zh-aishell3/tokens.txt
VOS_RS_IVR_TTS_LEXICON_PATH=models/ivr/vits-icefall-zh-aishell3/lexicon.txt
VOS_RS_IVR_ASR_ENABLED=false
VOS_RS_IVR_ASR_MODEL_PATH=models/ivr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/model.int8.onnx
VOS_RS_IVR_ASR_TOKENS_PATH=models/ivr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/tokens.txt
