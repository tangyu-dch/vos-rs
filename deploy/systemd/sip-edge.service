[Unit]
Description=VOS-RS SIP Edge (B2BUA + RTP Relay)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=vos-rs
Group=vos-rs
Environment=VOS_RS_CONFIG_FILE=/etc/vos-rs/config.yaml
ExecStart=/opt/vos-rs/bin/sip-edge
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
WorkingDirectory=/opt/vos-rs

# 安全加固
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/vos-rs/data/recordings /var/log/vos-rs
PrivateTmp=true

[Install]
WantedBy=multi-user.target
