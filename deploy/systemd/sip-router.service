[Unit]
Description=VOS-RS Native SIP Router
After=network.target redis.service
Wants=redis.service

[Service]
Type=simple
User=vos-rs
Group=vos-rs
Environment=VOS_RS_CONFIG_FILE=/etc/vos-rs/config.yaml
ExecStart=/opt/vos-rs/bin/sip-router
Restart=on-failure
RestartSec=5
LimitNOFILE=1048576
WorkingDirectory=/opt/vos-rs

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/vos-rs
PrivateTmp=true

[Install]
WantedBy=multi-user.target
