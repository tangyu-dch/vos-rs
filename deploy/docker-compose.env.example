# Docker Compose 自身的端口、卷和配置文件选择。
# 应用业务配置全部位于 config.yaml，本文件中的变量不会传入 Rust 服务。

POSTGRES_USER=vos_rs
POSTGRES_PASSWORD=vos_rs
POSTGRES_DB=vos_rs
POSTGRES_PORT=5432
REDIS_PORT=6379
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# 可使用绝对路径覆盖默认的 deploy/docker/config.compose.yaml。
VOS_RS_CONFIG_FILE_HOST=./config.compose.yaml

SIP_UDP_PORT=5060
SIP_TCP_PORT=5060
SIP_WS_PORT=5062
SIP_ROUTER_MANAGE_PORT=8083
MANAGE_PORT=8082
MEDIA_CONTROL_PORT=3030
RTP_PORT_MIN=40000
RTP_PORT_MAX=40100
API_HOST_PORT=8080
WEB_PORT=3000

RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=recordings
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
