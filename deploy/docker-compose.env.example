# Docker Compose 端口、卷、配置文件与生产密钥。
# 生产部署必须复制一份独立 config.yaml，并确保其中 PostgreSQL/Redis/NATS/RustFS 凭据
# 与下面的基础设施变量一致。

POSTGRES_USER=vos_rs
POSTGRES_PASSWORD=vos_rs
POSTGRES_DB=vos_rs
POSTGRES_PORT=5432
REDIS_PORT=6379
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# 可使用绝对路径覆盖默认的 deploy/docker/config.compose.yaml。
VOS_RS_CONFIG_FILE_HOST=./config.compose.yaml

# 生产覆盖文件要求以下值均为随机强密钥，不能沿用示例值。
VOS_RS_INTERNAL_SECRET=replace-with-at-least-24-random-characters
VOS_RS_SIP_AUTH_SECRET=replace-with-at-least-24-random-characters
VOS_RS_MEDIA_CONTROL_TOKEN=replace-with-at-least-24-random-characters
VOS_RS_API_JWT_SECRET=replace-with-at-least-32-random-characters
VOS_RS_ADMIN_PASSWORD=replace-with-strong-admin-password
VOS_RS_OPERATOR_PASSWORD=replace-with-strong-operator-password
VOS_RS_FINANCIER_PASSWORD=replace-with-strong-financier-password

NATS_USER=nats_admin
NATS_PASSWORD=replace-with-strong-nats-password
REDIS_PASSWORD=replace-with-strong-redis-password

SIP_UDP_PORT=5060
SIP_TCP_PORT=5060
SIP_WS_PORT=5062
SIP_ROUTER_MANAGE_PORT=8083
MANAGE_PORT=8082
MEDIA_CONTROL_PORT=3030
RTP_PORT_MIN=40000
RTP_PORT_MAX=40100
API_HOST_PORT=8080
WEB_PORT=3000

RUSTFS_ACCESS_KEY=replace-with-rustfs-access-key
RUSTFS_SECRET_KEY=replace-with-strong-rustfs-secret-key
RUSTFS_BUCKET=recordings
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
