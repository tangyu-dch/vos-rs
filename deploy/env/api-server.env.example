# VOS-RS api-server 生产环境配置
# 复制到 /etc/vos-rs/api-server.env 并修改

# 数据库
DATABASE_URL=postgres://vos_rs:CHANGE_ME@localhost:5432/vos_rs

# API 端口
API_PORT=8080

# 录音目录（必须与 sip-edge 一致）
VOS_RS_RECORDING_DIR=/opt/vos-rs/data/recordings

# sip-edge 管理 API 地址
VOS_RS_MANAGE_BASE=http://127.0.0.1:8082

# 日志
RUST_LOG=api_server=info,info
