# VOS-RS sip-edge 生产环境配置
# 复制到 /etc/vos-rs/sip-edge.env 并修改

# ═══════════════════════════════════════════════════════════════
# SIP 信令
# ═══════════════════════════════════════════════════════════════
VOS_RS_SIP_UDP_BIND=0.0.0.0:5060
VOS_RS_SIP_ADVERTISED_ADDR=your-public-ip:5060
VOS_RS_SIP_DEFAULT_GATEWAY=

# SIP TLS（可选）
VOS_RS_SIP_TLS_BIND=0.0.0.0:5061
VOS_RS_SIP_TLS_CERT_PATH=/etc/vos-rs/tls/sip.crt
VOS_RS_SIP_TLS_KEY_PATH=/etc/vos-rs/tls/sip.key
VOS_RS_SIP_TLS_CA_PATH=
VOS_RS_SIP_TLS_INSECURE_SKIP_VERIFY=false
VOS_RS_SIP_TLS_ALLOW_TEST_CERT=false

# SIP 认证
VOS_RS_SIP_AUTH_USERS=1001:secret,1002:secret
VOS_RS_SIP_AUTH_REALM=vos-rs

# ═══════════════════════════════════════════════════════════════
# RTP 媒体
# ═══════════════════════════════════════════════════════════════
VOS_RS_RTP_ADVERTISED_ADDR=your-public-ip
VOS_RS_RTP_PORT_MIN=40000
VOS_RS_RTP_PORT_MAX=60000
VOS_RS_RTP_SYMMETRIC_LEARNING=true

# ═══════════════════════════════════════════════════════════════
# 录音
# ═══════════════════════════════════════════════════════════════
VOS_RS_RECORDING_ENABLED=true
VOS_RS_RECORDING_DIR=/opt/vos-rs/data/recordings
VOS_RS_RECORDING_MAX_AGE_DAYS=30
VOS_RS_RECORDING_MAX_SIZE_MB=1024

# ═══════════════════════════════════════════════════════════════
# 数据库
# ═══════════════════════════════════════════════════════════════
VOS_RS_DATABASE_URL=postgres://vos_rs:CHANGE_ME@localhost:5432/vos_rs

# ═══════════════════════════════════════════════════════════════
# NATS（可选）
# ═══════════════════════════════════════════════════════════════
VOS_RS_NATS_URL=
VOS_RS_NATS_CDR_STREAM=VOS_RS_CDRS
VOS_RS_NATS_CDR_SUBJECT=vos-rs.cdrs

# ═══════════════════════════════════════════════════════════════
# 管理 API（仅内网）
# ═══════════════════════════════════════════════════════════════
VOS_RS_MANAGE_BIND=127.0.0.1:8082

# ═══════════════════════════════════════════════════════════════
# SBC 安全
# ═══════════════════════════════════════════════════════════════
VOS_RS_SBC_ALLOW=
VOS_RS_SBC_BLOCK=
VOS_RS_SBC_LIMIT_CAPACITY=100
VOS_RS_SBC_LIMIT_FILL_RATE=10
VOS_RS_SBC_MAX_CONCURRENCY=500

# ═══════════════════════════════════════════════════════════════
# 防盗打配置
# ═══════════════════════════════════════════════════════════════
# 启用防盗打
VOS_RS_ANTI_FRAUD_ENABLED=true

# 并发限制
VOS_RS_ANTI_FRAUD_MAX_CONCURRENT_ACCOUNT=50
VOS_RS_ANTI_FRAUD_MAX_CONCURRENT_IP=20

# 速率限制
VOS_RS_ANTI_FRAUD_MAX_CPS_ACCOUNT=10
VOS_RS_ANTI_FRAUD_MAX_CPS_GLOBAL=1000

# 通话时长限制
VOS_RS_ANTI_FRAUD_MIN_CALL_DURATION=3
VOS_RS_ANTI_FRAUD_MAX_CALL_DURATION=3600

# 短通话检测
VOS_RS_ANTI_FRAUD_SHORT_CALL_THRESHOLD=5
VOS_RS_ANTI_FRAUD_SHORT_CALL_WINDOW=60

# 号码过滤
VOS_RS_ANTI_FRAUD_BLOCKED_PREFIXES=116,168,160,161,162,167
VOS_RS_ANTI_FRAUD_ALLOWED_PREFIXES=
VOS_RS_ANTI_FRAUD_BLOCK_INTERNATIONAL=true
VOS_RS_ANTI_FRAUD_BLOCK_PREMIUM=true

# IP 过滤
VOS_RS_ANTI_FRAUD_BLOCKED_IPS=
VOS_RS_ANTI_FRAUD_ALLOWED_IPS=

# 余额控制
VOS_RS_ANTI_FRAUD_ALLOW_ZERO_BALANCE=false

# ═══════════════════════════════════════════════════════════════
# STUN/UPnP
# ═══════════════════════════════════════════════════════════════
VOS_RS_STUN_SERVER=
VOS_RS_UPNP_ENABLED=false

# ═══════════════════════════════════════════════════════════════
# 日志
# ═══════════════════════════════════════════════════════════════
RUST_LOG=sip_edge=info,info
