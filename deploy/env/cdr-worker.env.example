# VOS-RS cdr-worker 生产环境配置
# 复制到 /etc/vos-rs/cdr-worker.env 并修改

# 数据库
VOS_RS_DATABASE_URL=postgres://vos_rs:CHANGE_ME@localhost:5432/vos_rs

# NATS
VOS_RS_NATS_URL=nats://localhost:4222
VOS_RS_NATS_CDR_STREAM=VOS_RS_CDRS
VOS_RS_NATS_CDR_SUBJECT=vos-rs.cdrs
VOS_RS_NATS_CDR_CONSUMER=vos-rs-cdr-worker

# 日志
RUST_LOG=cdr_worker=info,info
