<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<scenario name="VOS-RS unavailable egress gateway UAS">
  <recv request="INVITE" crlf="true"/>
  <send>
    <![CDATA[
      SIP/2.0 503 Service Unavailable
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]failedEgress[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Retry-After: 1
      Content-Length: 0
    ]]>
  </send>
  <recv request="ACK"/>
  <timewait milliseconds="200"/>
</scenario>
