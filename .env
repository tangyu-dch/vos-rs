# VOS-RS local development defaults.
# Do not put production secrets in this file.

RUST_LOG=sip_edge=debug,cdr_worker=debug,info
PYTHON=python3
SIPP_BIN=sipp

LOCAL_IP=127.0.0.1
DESTINATION=13800138000
SIPP_TIMEOUT=15s
FULL_FLOW_TIMEOUT=8

VOS_RS_SIP_UDP_BIND=127.0.0.1:5062
VOS_RS_SIP_ADVERTISED_ADDR=127.0.0.1:5062
VOS_RS_SIP_DEFAULT_GATEWAY=127.0.0.1:5070
VOS_RS_SIP_UDP_RECEIVE_BUFFER=4194304
VOS_RS_SIP_UDP_SEND_BUFFER=4194304

# SIP TLS is disabled unless cert/key paths are configured.
VOS_RS_SIP_TLS_BIND=127.0.0.1:5061
VOS_RS_SIP_TLS_CERT_PATH=
VOS_RS_SIP_TLS_KEY_PATH=
VOS_RS_SIP_TLS_CA_PATH=
VOS_RS_SIP_TLS_SERVER_NAME=
VOS_RS_SIP_TLS_INSECURE_SKIP_VERIFY=false
VOS_RS_SIP_TLS_ALLOW_TEST_CERT=false

VOS_RS_SIP_AUTH_USERS=1001:secret,1002:secret
VOS_RS_SIP_AUTH_REALM=vos-rs
VOS_RS_SIP_AUTH_NONCE=dev-nonce

VOS_RS_RTP_ADVERTISED_ADDR=127.0.0.1
VOS_RS_RTP_PORT_MIN=40000
VOS_RS_RTP_PORT_MAX=40100
VOS_RS_RTP_SYMMETRIC_LEARNING=true

VOS_RS_RECORDING_ENABLED=false
VOS_RS_RECORDING_DIR=target/recordings
VOS_RS_RECORDING_WORKERS=4
VOS_RS_RECORDING_QUEUE_CAPACITY=4096

# Enable direct PostgreSQL CDR writes in sip-edge or cdr-worker when needed.
VOS_RS_DATABASE_URL=postgres://vos_rs:vos_rs@127.0.0.1:5432/vos_rs

# Enable NATS JetStream CDR queueing in sip-edge when needed.
VOS_RS_NATS_URL=nats://127.0.0.1:4223
VOS_RS_NATS_CDR_STREAM=VOS_RS_CDRS
VOS_RS_NATS_CDR_SUBJECT=vos-rs.cdrs
VOS_RS_NATS_CDR_CONSUMER=vos-rs-cdr-worker

DEV_LOG_DIR=target/dev
SMOKE_LOG_DIR=target/sipp
FULL_FLOW_LOG_DIR=target/full-flow
